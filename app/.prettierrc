{
  "tabWidth": 2,
  "printWidth": 80,
  "useTabs": false,
  "singleQuote": false,
  "trailingComma": "none",
  "plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": "*.svelte",
      "options": {
        "parser": "svelte",
        "bracketSameLine": true
      }
    }
  ]
}
