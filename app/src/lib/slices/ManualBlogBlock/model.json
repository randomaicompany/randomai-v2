{
  "id": "manual_blog_block",
  "type": "SharedSlice",
  "name": "ManualBlogBlock",
  "description": "Display manually created blog posts in a carousel",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default variation",
      "imageUrl": "",
      "primary": {
        "heading": {
          "type": "StructuredText",
          "config": {
            "label": "Section Heading",
            "placeholder": "Latest from Random AI",
            "allowTargetBlank": false,
            "single": "heading2"
          }
        }
      },
      "items": {
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "",
            "allowTargetBlank": false,
            "single": "heading3"
          }
        },
        "featured_image": {
          "type": "Image",
          "config": {
            "label": "Featured Image",
            "constraint": {
              "width": 800,
              "height": 450
            },
            "thumbnails": []
          }
        },
        "excerpt": {
          "type": "StructuredText",
          "config": {
            "label": "Excerpt",
            "placeholder": "",
            "allowTargetBlank": false,
            "single": "paragraph"
          }
        },
        "content": {
          "type": "StructuredText",
          "config": {
            "label": "Content",
            "placeholder": "",
            "allowTargetBlank": true,
            "multi": "paragraph,heading3,heading4,strong,em,hyperlink,list-item,o-list-item,image"
          }
        },
        "categories": {
          "type": "Text",
          "config": {
            "label": "Categories (comma-separated)",
            "placeholder": "AI, Design, Tutorial"
          }
        },
        "author": {
          "type": "Text",
          "config": {
            "label": "Author Name",
            "placeholder": ""
          }
        },
        "publish_date": {
          "type": "Date",
          "config": {
            "label": "Publish Date",
            "placeholder": ""
          }
        }
      }
    }
  ]
}