        "config": {
          "choices": {
            "rss_block": {
              "type": "SharedSlice"
            },
            "hero": {
              "type": "SharedSlice"
            },
            "breadcrumbs": {
              "type": "SharedSlice"
            },
            "video": {
              "type": "SharedSlice"
            },
            "blank_space": {
              "type": "SharedSlice"
            },
            "cards": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
