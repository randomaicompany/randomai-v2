{
  "format": "page",
  "id": "page",
  "label": "Page",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "config": {
          "label": "UID"
        },
        "type": "UID"
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "iframe_embed": {
              "type": "SharedSlice"
            },
            "custom_embed": {
              "type": "SharedSlice"
            },
            "gallery": {
              "type": "SharedSlice"
            },
            "accordions": {
              "type": "SharedSlice"
            },
            "content_body": {
              "type": "SharedSlice"
            },
            "breadcrumbs": {
              "type": "SharedSlice"
            },
            "blank_space": {
              "type": "SharedSlice"
            },
            "video": {
              "type": "SharedSlice"
            },
            "cards": {
              "type": "SharedSlice"
            },
            "hero": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_image": {
        "type": "Image",
        "config": {
          "label": "Meta Image",
          "constraint": {},
          "thumbnails": []
        }
      }
    },
    "Custom Code": {
      "head": {
        "type": "StructuredText",
        "config": {
          "label": "Head",
          "placeholder": "",
          "allowTargetBlank": false,
          "single": "preformatted"
        }
      },
      "body": {
        "type": "StructuredText",
        "config": {
          "label": "Body",
          "placeholder": "",
          "allowTargetBlank": false,
          "single": "preformatted"
        }
      }
    }
  }
}
