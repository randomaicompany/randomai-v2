{
  "format": "page",
  "id": "collection",
  "label": "Collection",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "config": {
          "label": "UID"
        },
        "type": "UID"
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "blank_space": {
              "type": "SharedSlice"
            },
            "breadcrumbs": {
              "type": "SharedSlice"
            },
            "collection_product_card": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      }
    },
    "Custom Code": {
      "head": {
        "type": "StructuredText",
        "config": {
          "label": "Head",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "preformatted"
        }
      },
      "body": {
        "type": "StructuredText",
        "config": {
          "label": "Body",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "preformatted"
        }
      }
    }
  }
}
